# Local DataHub Quickstart (development only)
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_FRONTEND_URL=http://localhost:9002
DATAHUB_USERNAME=datahub
DATAHUB_PASSWORD=datahub
DATAHUB_TOKEN=

# Optional LLM provider; deterministic checks do not require an LLM.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# WP6 bounded API and the future local command-center origin.
SCIGUARD_RUN_ROOT=.sciguard/runs
SCIGUARD_REPLAY_ROOT=examples/replays
SCIGUARD_UI_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
